diff --git a/src/styles.scss b/src/styles.scss
index 808f1e6..6cb71e7 100644
--- a/src/styles.scss
+++ b/src/styles.scss
@@ -2415,3 +2415,250 @@ body.gsap-missing {
     transform: none !important;
   }
 }
+
+
+/* UX polish patch: guided invitation, intro controls, clearer RSVP states */
+.trailer-skip {
+  position: fixed;
+  top: max(16px, env(safe-area-inset-top));
+  right: 16px;
+  z-index: 6;
+  min-height: 40px;
+  padding: 0 15px;
+  border: 1px solid rgba(255,255,255,.24);
+  border-radius: 999px;
+  background: rgba(7, 20, 45, .58);
+  color: #fff;
+  font-weight: 900;
+  letter-spacing: .02em;
+  box-shadow: 0 14px 34px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.22);
+  backdrop-filter: blur(14px);
+  cursor: pointer;
+}
+
+.trailer-skip:hover,
+.trailer-skip:focus-visible {
+  transform: translateY(-1px);
+  border-color: rgba(255, 215, 45, .7);
+  box-shadow: 0 16px 38px rgba(0,0,0,.32), 0 0 24px rgba(255, 215, 45, .18);
+}
+
+.trailer-hud {
+  position: absolute;
+  left: clamp(18px, 6vw, 72px);
+  bottom: clamp(28px, 9vh, 90px);
+  z-index: 3;
+  display: grid;
+  gap: 4px;
+  padding: 16px 18px;
+  border: 1px solid rgba(255,255,255,.18);
+  border-radius: 20px;
+  background: linear-gradient(135deg, rgba(255,255,255,.14), rgba(255,255,255,.04)), rgba(5, 17, 40, .6);
+  box-shadow: 0 22px 60px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.18);
+  backdrop-filter: blur(16px);
+}
+
+.trailer-hud span {
+  color: var(--yellow);
+  font-size: .78rem;
+  font-weight: 1000;
+  text-transform: uppercase;
+  letter-spacing: .18em;
+}
+
+.trailer-hud strong {
+  font-size: clamp(1.6rem, 7vw, 3.5rem);
+  line-height: .9;
+  text-transform: uppercase;
+  text-shadow: 0 8px 0 rgba(0,0,0,.32), 0 0 24px rgba(26,141,255,.44);
+}
+
+.trailer-energy {
+  position: absolute;
+  inset: 0;
+  z-index: 1;
+  pointer-events: none;
+  overflow: hidden;
+}
+
+.trailer-energy i {
+  position: absolute;
+  left: -12vw;
+  width: 124vw;
+  height: 3px;
+  border-radius: 999px;
+  background: linear-gradient(90deg, transparent, rgba(127, 230, 255, .92), rgba(255, 215, 45, .82), transparent);
+  box-shadow: 0 0 28px rgba(127, 230, 255, .42);
+  transform: rotate(-12deg);
+}
+
+.trailer-energy i:nth-child(1) { top: 22%; }
+.trailer-energy i:nth-child(2) { top: 50%; transform: rotate(9deg); }
+.trailer-energy i:nth-child(3) { top: 72%; }
+
+.welcome-card {
+  width: min(100%, 520px);
+  margin: 16px auto 0;
+  padding: 18px;
+  border-radius: var(--radius-lg);
+  border: 1px solid rgba(255,255,255,.16);
+  background:
+    radial-gradient(circle at 12% 0%, rgba(255,215,45,.20), transparent 38%),
+    linear-gradient(135deg, rgba(21, 92, 202, .74), rgba(8, 25, 60, .72));
+  box-shadow: 0 22px 55px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.20);
+  backdrop-filter: blur(16px);
+}
+
+.welcome-kicker {
+  display: inline-flex;
+  margin-bottom: 8px;
+  color: var(--yellow);
+  font-size: .78rem;
+  font-weight: 1000;
+  text-transform: uppercase;
+  letter-spacing: .14em;
+}
+
+.welcome-card p {
+  margin: 0;
+  font-size: clamp(1.1rem, 4.3vw, 1.55rem);
+  line-height: 1.16;
+  font-weight: 850;
+}
+
+.welcome-card small {
+  display: block;
+  margin-top: 8px;
+  color: rgba(255,255,255,.78);
+  font-weight: 800;
+}
+
+.welcome-cta {
+  width: 100%;
+  min-height: 48px;
+  margin-top: 14px;
+  border: 0;
+  border-radius: 16px;
+  color: #061832;
+  background: linear-gradient(180deg, #fff4a6, var(--yellow) 58%, #ffb71b);
+  box-shadow: 0 14px 30px rgba(255, 190, 26, .22), inset 0 1px 0 rgba(255,255,255,.74);
+  font-weight: 1000;
+  text-transform: uppercase;
+  letter-spacing: .03em;
+  cursor: pointer;
+}
+
+.welcome-cta:hover,
+.welcome-cta:focus-visible {
+  transform: translateY(-1px);
+  filter: brightness(1.05);
+}
+
+.action-card .quick-links {
+  gap: 14px;
+}
+
+.quick-links a.route-card {
+  min-height: 90px;
+  border-color: rgba(127, 230, 255, .46);
+  background:
+    radial-gradient(circle at 8% 0%, rgba(127,230,255,.26), transparent 42%),
+    linear-gradient(135deg, rgba(26,141,255,.34), rgba(255,255,255,.07));
+}
+
+.quick-links a.route-card .link-icon {
+  background: linear-gradient(180deg, rgba(127,230,255,.26), rgba(26,141,255,.26));
+  border-color: rgba(127,230,255,.44);
+}
+
+.mobile-dock.floating-rsvp {
+  grid-template-columns: 1fr 1fr;
+  align-items: stretch;
+  padding-top: 16px;
+}
+
+.mobile-dock.floating-rsvp .dock-status {
+  grid-column: 1 / -1;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  gap: 9px;
+  min-height: 30px;
+  margin: -2px 2px 2px;
+  padding: 6px 10px;
+  border-radius: 999px;
+  border: 1px solid rgba(255,255,255,.16);
+  background: rgba(255,255,255,.08);
+  color: rgba(255,255,255,.9);
+  font-size: .78rem;
+  font-weight: 900;
+  text-align: center;
+  box-shadow: inset 0 1px 0 rgba(255,255,255,.14);
+}
+
+.dock-status-dot {
+  width: 9px;
+  height: 9px;
+  border-radius: 50%;
+  background: var(--green);
+  box-shadow: 0 0 18px rgba(88, 255, 154, .62);
+  flex: 0 0 auto;
+}
+
+.mobile-dock.floating-rsvp .dock-actions {
+  grid-column: 1 / -1;
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: clamp(10px, 2.6vw, 18px);
+  width: 100%;
+}
+
+.mobile-dock.floating-rsvp .dock-btn.is-saved {
+  opacity: .78;
+  filter: saturate(.85);
+  cursor: default;
+}
+
+.mobile-dock.floating-rsvp .dock-btn.is-saved strong::after {
+  content: "";
+}
+
+.guest-name-modal {
+  padding: max(24px, env(safe-area-inset-top)) 16px max(24px, env(safe-area-inset-bottom));
+}
+
+.guest-name-panel.is-shaking {
+  animation: guestNameShake .44s ease both;
+}
+
+@keyframes guestNameShake {
+  0%, 100% { transform: translateX(0); }
+  18% { transform: translateX(-10px); }
+  36% { transform: translateX(9px); }
+  54% { transform: translateX(-7px); }
+  72% { transform: translateX(5px); }
+}
+
+@media (max-width: 560px) {
+  .trailer-hud {
+    left: 14px;
+    right: 14px;
+    bottom: 88px;
+  }
+
+  .trailer-character {
+    transform-origin: 58% 72%;
+  }
+
+  .welcome-card {
+    padding: 16px;
+  }
+
+  .mobile-dock.floating-rsvp .dock-status {
+    font-size: .7rem;
+  }
+
+  .mobile-dock.floating-rsvp .dock-actions {
+    gap: 10px;
+  }
+}
